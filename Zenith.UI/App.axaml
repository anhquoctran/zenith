<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zenith.UI.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon ToolTipText="Zenith Screen Recorder">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show Main Window" Click="NativeMenuItem_Show_Click" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" Click="NativeMenuItem_Exit_Click" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

</Application>