<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:data="using:Zenith.Data"
        xmlns:core="using:Zenith.Core"
        xmlns:local="using:Zenith.UI"
        x:Class="Zenith.UI.MainWindow"
        Title="Zenith"
        Icon="/Assets/logo.png"
        Width="1280" 
        Height="720"
        MinHeight="720"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True">
    
    <Window.Resources>
        <local:PathToBitmapConverter x:Key="PathToBitmapConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0098FF"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" /> <!-- Title Bar Area (Empty for dragging) -->
            <RowDefinition Height="Auto" /> <!-- Menu -->
            <RowDefinition Height="*" /> <!-- Main Layout -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <Border Grid.Row="1" Height="30" Background="#1A1A1A" BorderBrush="#222222" BorderThickness="0,0,0,1">
            <Menu Background="Transparent" FontSize="12"  Foreground="#ECECEC" VerticalAlignment="Center" Margin="10,0,0,0">
                <MenuItem Header="_File">
                    <MenuItem Header="Show Recordings"/>
                    <MenuItem Header="Remux Recordings"/>
                    <Separator/>
                    <MenuItem Header="Settings"/>
                    <Separator/>
                    <MenuItem Header="Exit"/>
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="Undo"/>
                    <MenuItem Header="Redo"/>
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="Docks"/>
                </MenuItem>
                <MenuItem Header="_Profile">
                    <MenuItem Header="Default"/>
                </MenuItem>
                <MenuItem Header="_Scene Collection">
                    <MenuItem Header="Default"/>
                </MenuItem>
                <MenuItem Header="_Tools">
                    <MenuItem Header="Scripts"/>
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="About Zenith"/>
                </MenuItem>
            </Menu>
        </Border>

        <!-- Main Content (OBS-style Layout) -->
        <Grid Grid.Row="2" RowDefinitions="*, 300" ColumnDefinitions="350, *, 300" Margin="4,4,4,4" RowSpacing="4" ColumnSpacing="4">
            
            <!-- Dock 0: History -->
            <Border Grid.Row="0" Grid.Column="0" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" Text="Recording History" FontWeight="Bold" FontSize="12" Foreground="#ECECEC" VerticalAlignment="Center"/>
                        <Button x:Name="BtnClearHistory" Click="BtnClearHistory_Click" Grid.Column="1" ToolTip.Tip="Clear History" Width="28" Height="28" CornerRadius="14" Margin="0,0,5,0" Padding="0">
                            <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf1f8;" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnRefreshHistory" Click="BtnRefreshHistory_Click" Grid.Column="2" ToolTip.Tip="Refresh" Width="28" Height="28" CornerRadius="14" Padding="0">
                            <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf021;" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                    
                    <ListBox x:Name="HistoryListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,-5,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="data:Record">
                                <Border Background="#2D2D30" CornerRadius="6" Padding="8" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Width="60" Height="34" Background="#111111" CornerRadius="4" ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToBitmapConverter}}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontWeight="SemiBold" FontSize="13" Foreground="#ECECEC"/>
                                            <TextBlock Text="{Binding Resolution}" Foreground="#AAAAAA" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Duration, StringFormat={}{0:hh\\:mm\\:ss}}" Foreground="#ECECEC" VerticalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel x:Name="EmptyHistoryPlaceholder" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="5" IsVisible="False">
                        <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" Foreground="#555555"/>
                        <TextBlock Text="No recordings" FontSize="13" FontWeight="SemiBold" Foreground="#888888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Preview Area -->
            <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition MaxHeight="50" />
                    </Grid.RowDefinitions>

                    <Viewbox Grid.Row="0" Stretch="Uniform">
                        <Grid Width="1920" Height="1080">
                            <Image x:Name="PreviewImage" Stretch="Fill" />
                            <local:VisualLayerEditor x:Name="LayerEditor" />
                        </Grid>
                    </Viewbox>

                    <Border Grid.Row="1" BorderThickness="1" Padding="15">
                        <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="ElapsedTimeText" Text="00:00:00" Foreground="White" FontSize="13" FontWeight="Regular" HorizontalAlignment="Center" IsVisible="true"/>
                            <Button x:Name="RecordButton" Click="RecordButton_Click" Background="Transparent" Foreground="White" Width="38" Height="38" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Record">
                                <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf111;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button x:Name="StopButton" Click="StopButton_Click" Background="Transparent" Foreground="White" Width="38" Height="38" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsEnabled="False" ToolTip.Tip="Stop">
                                <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf04d;" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Dock 1: Sources (Video Layers) -->
            <Border Grid.Row="1" Grid.Column="0" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Sources" FontWeight="Bold" FontSize="12" Foreground="#ECECEC" Margin="0,0,0,5"/>
                    
                    <ListBox x:Name="VideoLayersListBox" Grid.Row="1" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" CornerRadius="0" Padding="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="MinHeight" Value="24"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:VideoLayer">
                                <Grid ColumnDefinitions="Auto, *, Auto" Margin="2">
                                    <TextBlock Grid.Column="0" FontFamily="{StaticResource FontAwesome}" Text="&#xf06e;" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="5,0,10,0" FontSize="10"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Name}" VerticalAlignment="Center" Foreground="#ECECEC" FontSize="12"/>
                                    <TextBlock Grid.Column="2" FontFamily="{StaticResource FontAwesome}" Text="&#xf023;" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="10,0,5,0" FontSize="10"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2" Background="#2B2B2B" BorderThickness="1,0,1,1" BorderBrush="#333333" Height="26" Margin="0">
                        <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                            <Button Grid.Column="0" Content="+" x:Name="AddVideoLayerButton" Click="AddVideoLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Add Source"/>
                            <Button Grid.Column="1" Content="-" x:Name="RemoveVideoLayerButton" Click="RemoveVideoLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Remove Source"/>
                            
                            <ComboBox Grid.Column="2" x:Name="AddVideoLayerTypeComboBox" SelectedIndex="0" Height="20" FontSize="10" VerticalAlignment="Center" Margin="5,0" Padding="5,0" MinHeight="20">
                                <ComboBoxItem Content="Screen" />
                                <ComboBoxItem Content="Image" />
                                <ComboBoxItem Content="Video File" />
                                <ComboBoxItem Content="Text" />
                            </ComboBox>

                            <Button Grid.Column="3" Content="^" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Move Up"/>
                            <Button Grid.Column="4" Content="v" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Move Down"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Dock 2: Mixer & Output -->
            <Border Grid.Row="1" Grid.Column="1" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="Audio Mixer" FontWeight="Bold" FontSize="12" Foreground="#ECECEC" Margin="0,0,0,5"/>
                    
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ListBox x:Name="AudioLayersListBox" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" CornerRadius="0" Padding="0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="2,2,0,2"/>
                                    <Setter Property="VerticalAlignment" Value="Top"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:AudioLayer">
                                    <Border BorderThickness="0,0,1,0" BorderBrush="#333333" Width="95" Background="Transparent">
                                        <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
                                            
                                            <!-- Row 0: Active Bar -->
                                            <Border Grid.Row="0" Background="#112C66" Padding="0,3">
                                                <TextBlock Text="Active" Foreground="#5B8EEA" FontSize="10" TextAlignment="Center" FontWeight="SemiBold"/>
                                            </Border>
                                            
                                            <!-- Row 1: Name and Dropdown -->
                                            <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="5,5,5,2">
                                                <TextBlock Grid.Column="0" Text="{Binding Name}" TextAlignment="Left" TextTrimming="CharacterEllipsis" FontSize="11" Foreground="#ECECEC" VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1" FontFamily="{StaticResource FontAwesome}" Text="&#xf0d7;" Foreground="#ECECEC" FontSize="10" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                            </Grid>
                                            
                                            <!-- Row 2: dB Value -->
                                            <TextBlock Grid.Row="2" Text="{Binding Volume, StringFormat=\{0:0.0\} dB}" FontSize="11" Foreground="#888888" Margin="5,0,5,10"/>
                                            
                                            <!-- Row 3: Sliders and Meters -->
                                            <Grid Grid.Row="3" ColumnDefinitions="Auto, Auto, Auto" HorizontalAlignment="Center" Margin="0,0,0,10">
                                                <!-- Slider -->
                                                <Slider Grid.Column="0" Orientation="Vertical" Value="{Binding Volume}" Minimum="0" Maximum="1" Height="140" HorizontalAlignment="Left" Margin="0,0,5,0" />
                                                
                                                <!-- Stereo Meters -->
                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="2">
                                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="1" Value="{Binding CurrentPeak}" Width="6" CornerRadius="0" BorderThickness="0" Background="#111111">
                                                        <ProgressBar.Foreground>
                                                            <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                                                                <GradientStop Color="#28A745" Offset="0.0" />
                                                                <GradientStop Color="#28A745" Offset="0.6" />
                                                                <GradientStop Color="#FFC107" Offset="0.75" />
                                                                <GradientStop Color="#DC3545" Offset="0.9" />
                                                            </LinearGradientBrush>
                                                        </ProgressBar.Foreground>
                                                    </ProgressBar>
                                                    <ProgressBar Orientation="Vertical" Minimum="0" Maximum="1" Value="{Binding CurrentPeak}" Width="6" CornerRadius="0" BorderThickness="0" Background="#111111">
                                                        <ProgressBar.Foreground>
                                                            <LinearGradientBrush StartPoint="0%,100%" EndPoint="0%,0%">
                                                                <GradientStop Color="#28A745" Offset="0.0" />
                                                                <GradientStop Color="#28A745" Offset="0.6" />
                                                                <GradientStop Color="#FFC107" Offset="0.75" />
                                                                <GradientStop Color="#DC3545" Offset="0.9" />
                                                            </LinearGradientBrush>
                                                        </ProgressBar.Foreground>
                                                    </ProgressBar>
                                                </StackPanel>
                                                
                                                <!-- Tick Marks -->
                                                <Grid Grid.Column="2" RowDefinitions="*,*,*,*,*,*,*,*,*,*,*" Margin="4,0,0,0">
                                                    <TextBlock Grid.Row="0" Text="- 0" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="1" Text="- 6" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="2" Text="- 12" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="3" Text="- 18" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="4" Text="- 24" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="5" Text="- 30" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="6" Text="- 36" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="7" Text="- 42" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="8" Text="- 48" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="9" Text="- 54" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Row="10" Text="- 60" FontSize="8" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                                </Grid>
                                            </Grid>
                                            
                                            <!-- Row 4: Bottom Icons -->
                                            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,0,0,10">
                                                <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf028;" Foreground="#ECECEC" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf013;" Foreground="#ECECEC" FontSize="14" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#2B2B2B" BorderThickness="1,0,1,1" BorderBrush="#333333" Height="26" Margin="0">
                        <Grid ColumnDefinitions="Auto, Auto, *">
                            <Button Grid.Column="0" Content="+" x:Name="AddAudioLayerButton" Click="AddAudioLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Add Audio Source"/>
                            <Button Grid.Column="1" Content="-" x:Name="RemoveAudioLayerButton" Click="RemoveAudioLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Remove Audio Source"/>
                            
                            <ComboBox Grid.Column="2" x:Name="AddAudioLayerTypeComboBox" SelectedIndex="0" Height="20" FontSize="10" VerticalAlignment="Center" Margin="5,0" Padding="5,0" MinHeight="20" HorizontalAlignment="Right">
                                <ComboBoxItem Content="Microphone" />
                                <ComboBoxItem Content="System Audio" />
                            </ComboBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Dock 3: Settings -->
            <Border Grid.Row="1" Grid.Column="2" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>


                        <StackPanel Grid.Row="1">
                            <TextBlock Text="Hardware Encoder" FontWeight="SemiBold" FontSize="12" Foreground="#AAAAAA" Margin="0,5,0,0"/>
                            <ComboBox x:Name="GpuComboBox" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="GpuComboBox_SelectionChanged">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="core:GPUDevice">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Row="2" x:Name="GpuWarningPanel" Orientation="Horizontal" Spacing="5" Margin="0,2,0,0" IsVisible="False">
                                <TextBlock Text="⚠" Foreground="#FFCC00" FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock Text="Cross-adapter encoding warning." Foreground="#FFCC00" TextWrapping="Wrap" FontSize="10" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Row="3">
                            <CheckBox x:Name="HardwareAccelerationCheckBox" Content="Use HW Acceleration" IsChecked="True" Foreground="#AAAAAA" FontSize="12" Margin="0,2,0,0"/>

                            <TextBlock Text="Save Location" FontWeight="SemiBold" FontSize="12" Foreground="#AAAAAA" Margin="0,5,0,0"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox x:Name="SaveLocationTextBox" Grid.Column="0" IsReadOnly="True" Margin="0,0,5,0" VerticalAlignment="Center" Height="28" FontSize="11" Padding="5,4"/>
                                <Button x:Name="SelectFolderButton" Grid.Column="1" Content="..." Click="SelectFolder_Click" Classes="accent" VerticalAlignment="Center" Height="28" Width="32" Padding="0" HorizontalContentAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Grid>
            </Border> 
        </Grid>

        <Border Grid.Row="3" Background="#111111" Padding="15,4" BorderBrush="#222222" BorderThickness="0,1,0,0" Height="28">
            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="15">
                    <TextBlock x:Name="AppVersionText" Text="Zenith v1.0.0" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FFmpegVersionText" Text="FFmpeg vX.X" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15">
                    <TextBlock x:Name="CpuUsageText" Text="CPU: 0%" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="MemUsageText" Text="Mem: 0 MB" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="GpuUsageText" Text="GPU: N/A" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
