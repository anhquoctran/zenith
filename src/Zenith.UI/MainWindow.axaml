<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:data="using:Zenith.Data"
        xmlns:core="using:Zenith.Core"
        xmlns:local="using:Zenith.UI"
        x:Class="Zenith.UI.MainWindow"
        Title="Zenith"
        Icon="/Assets/logo.png"
        Width="900" 
        Height="850"
        MinHeight="850"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True">
    
    <Window.Resources>
        <local:PathToBitmapConverter x:Key="PathToBitmapConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0098FF"/>
        </Style>
    </Window.Styles>

    <Panel>
        <!-- Main Content -->
        <Grid ColumnDefinitions="350,*" Margin="0,30,0,28">
        <Border Grid.Column="0" Background="#252526" BorderBrush="#333333" BorderThickness="0,0,1,0" Padding="20">
            <StackPanel Spacing="15">
                <TextBlock Text="Source Selection" FontSize="20" FontWeight="Bold" Foreground="#ECECEC"/>
                
                <TextBlock Text="Video Source" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,10,0,0"/>
                <ComboBox x:Name="VideoSourceComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" SelectionChanged="VideoSourceComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="core:VideoSource">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                
                <TextBlock Text="Camera" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,10,0,0"/>
                <ComboBox x:Name="CameraComboBox" SelectedIndex="0" HorizontalAlignment="Stretch" SelectionChanged="CameraComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="core:WebcamSource">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Audio Source" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,10,0,0"/>
                <ComboBox x:Name="AudioSourceComboBox" SelectedIndex="0" HorizontalAlignment="Stretch">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="core:AudioSource">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <Border Background="#1A1A1A" CornerRadius="8" Height="60" Margin="0,10,0,0">
                    <Canvas x:Name="WaveformCanvas" ClipToBounds="True">
                        <!-- Waveform drawn here via code-behind -->
                    </Canvas>
                </Border>

                  <CheckBox x:Name="HardwareAccelerationCheckBox" Content="Use Hardware Acceleration (GPU)" IsChecked="True" Foreground="#AAAAAA" Margin="0,5,0,0"/>

                 <TextBlock Text="Hardware Encoder" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,10,0,0"/>
                 <ComboBox x:Name="GpuComboBox" HorizontalAlignment="Stretch" SelectedIndex="0" SelectionChanged="GpuComboBox_SelectionChanged">
                     <ComboBox.ItemTemplate>
                         <DataTemplate x:DataType="core:GPUDevice">
                             <TextBlock Text="{Binding Name}" />
                         </DataTemplate>
                     </ComboBox.ItemTemplate>
                 </ComboBox>
                 
                 <StackPanel x:Name="GpuWarningPanel" Orientation="Horizontal" Spacing="5" Margin="0,5,0,0" IsVisible="False">
                     <TextBlock Text="⚠" Foreground="#FFCC00" FontWeight="Bold" VerticalAlignment="Center"/>
                     <TextBlock Text="Selected GPU differs from display GPU. Cross-adapter encoding may reduce performance." Foreground="#FFCC00" TextWrapping="Wrap" FontSize="11" VerticalAlignment="Center"/>
                 </StackPanel>

                <TextBlock Text="Save Location" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,10,0,0"/>
                <Grid ColumnDefinitions="*,Auto">
                    <TextBox x:Name="SaveLocationTextBox" Grid.Column="0" IsReadOnly="True" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <Button x:Name="SelectFolderButton" Grid.Column="1" Content="..." Click="SelectFolder_Click" Classes="accent" VerticalAlignment="Center"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                    <Button x:Name="RecordButton" Click="RecordButton_Click" Background="#FF4444" Foreground="White" Width="48" Height="48" CornerRadius="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="Record">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf111;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="StopButton" Click="StopButton_Click" Background="#007ACC" Foreground="White" Width="48" Height="48" CornerRadius="24" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsEnabled="False" ToolTip.Tip="Stop">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf04d;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
                
                <TextBlock x:Name="ElapsedTimeText" Text="00:00:00" Foreground="#FF4444" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" IsVisible="False"/>
            </StackPanel>
        </Border>

        <!-- Right Pane: Preview & History -->
        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Preview" FontSize="20" FontWeight="Bold" Foreground="#ECECEC" Margin="0,0,0,10"/>
            
                <Border Grid.Row="1" Background="#252526" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" MinHeight="300" MaxHeight="500" Margin="0,0,0,20" ClipToBounds="True">
                    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Image x:Name="PreviewImage" Stretch="Uniform" />
                        <Border x:Name="CameraPreviewOverlay" IsVisible="False" CornerRadius="8" BorderBrush="#555555" BorderThickness="2" Width="160" Height="90" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10" ClipToBounds="True">
                            <Image x:Name="CameraPreviewImage" Stretch="UniformToFill" />
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" VerticalAlignment="Center" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Recording History" FontSize="20" FontWeight="Bold" Foreground="#ECECEC" Margin="0,0,0,15"/>
                    <Button x:Name="BtnClearHistory" Click="BtnClearHistory_Click" Grid.Column="1" ToolTip.Tip="Clear History" Width="38" Height="38" CornerRadius="19" Margin="0,0,10,0">
                        <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf1f8;" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="BtnRefreshHistory" Click="BtnRefreshHistory_Click" HorizontalAlignment="Right" Grid.Column="2" ToolTip.Tip="Refresh" Width="38" Height="38" CornerRadius="19" >
                        <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf021;" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </Grid>

                
                <ListBox x:Name="HistoryListBox" Grid.Row="1" Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="data:Record">
                            <Border Background="#2D2D30" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <Border Grid.Column="0" Width="100" Height="56" Background="#111111" CornerRadius="4" ClipToBounds="True">
                                        <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToBitmapConverter}}" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock 
                                            Text="{Binding FileName}" 
                                            TextTrimming="CharacterEllipsis" 
                                            TextWrapping="NoWrap" 
                                            FontWeight="SemiBold"
                                            FontSize="16" 
                                            Foreground="#ECECEC"
                                            />
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <TextBlock Text="{Binding Resolution}" Foreground="#AAAAAA" FontSize="12"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{Binding Duration, StringFormat={}{0:hh\\:mm\\:ss}}" Foreground="#ECECEC" VerticalAlignment="Center" FontSize="14" FontWeight="Medium"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- Placeholder when history is empty -->
                <StackPanel x:Name="EmptyHistoryPlaceholder" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="10" IsVisible="False">
                    <TextBlock Text="📁" FontSize="48" HorizontalAlignment="Center" Foreground="#555555"/>
                    <TextBlock Text="No recordings yet" FontSize="16" FontWeight="SemiBold" Foreground="#888888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Your recorded screen videos will appear here." FontSize="12" Foreground="#666666" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
        
    <!-- Bottom Info Bar -->
        <Border VerticalAlignment="Bottom" Background="#111111" Padding="15,4" BorderBrush="#222222" BorderThickness="0,1,0,0" Height="28">
            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="15">
                    <TextBlock x:Name="AppVersionText" Text="Zenith v1.0.0" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FFmpegVersionText" Text="FFmpeg vX.X" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15">
                    <TextBlock x:Name="CpuUsageText" Text="CPU: 0%" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="MemUsageText" Text="Mem: 0 MB" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="GpuUsageText" Text="GPU: N/A" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Panel>
</Window>
