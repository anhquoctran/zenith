<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Zenith.UI.Controls"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:core="using:Zenith.Core"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="Zenith.UI.Views.LayerPropertiesWindow"
        Title="{DynamicResource Title_Properties}" Width="400" Height="450"
        WindowStartupLocation="CenterOwner"
        CanMaximize="False"
        CanMinimize="False"
        CanResize="False"
        Background="#1E1E1E">
    <Grid RowDefinitions="Auto,*,Auto" Margin="15">
        <TextBlock Grid.Row="0" Text="{DynamicResource Title_Properties}" FontSize="16" FontWeight="Bold" Foreground="#ECECEC" Margin="0,0,0,15"/>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="10">
                <TextBlock Text="{DynamicResource Lbl_Name}" Foreground="#AAAAAA" FontSize="12"/>
                <TextBox x:Name="NameTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                
                <StackPanel x:Name="TextPropertiesPanel" Spacing="10" IsVisible="False">
                    <TextBlock Text="{DynamicResource Auto_TextContent}" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                    <TextBox x:Name="TextContentTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" AcceptsReturn="True" Height="80"/>
                    
                    <TextBlock Text="{DynamicResource Auto_FontFamily}" Foreground="#AAAAAA" FontSize="12"/>
                    <TextBox x:Name="FontFamilyTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                    
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="{DynamicResource Auto_FontSize}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <NumericUpDown x:Name="FontSizeNumeric" Minimum="8" Maximum="800" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="{DynamicResource Auto_FontColorHex}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <TextBox x:Name="FontColorTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                        </StackPanel>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="{DynamicResource Auto_FontStyle}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <ComboBox x:Name="FontStyleComboBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="{DynamicResource Auto_Normal}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Italic}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Oblique}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="{DynamicResource Auto_FontWeight}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <ComboBox x:Name="FontWeightComboBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="{DynamicResource Auto_Normal}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Bold}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Light}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Black}"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                            <TextBlock Text="{DynamicResource Auto_Alignment}" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <ComboBox x:Name="TextAlignmentComboBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="{DynamicResource Auto_Left}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Center}"/>
                                <ComboBoxItem Content="{DynamicResource Auto_Right}"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="FilePropertiesPanel" Spacing="10" IsVisible="False">
                    <TextBlock Text="{DynamicResource Auto_FilePath}" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="FilePathTextBox" Grid.Column="0" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" Margin="0,0,5,0"/>
                        <Button x:Name="BrowseFileButton" Grid.Column="1" Content="..." Width="30" Click="BrowseFileButton_Click" Background="#333333" Foreground="#ECECEC" HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="CameraPropertiesPanel" Spacing="10" IsVisible="False">
                    <TextBlock Text="{DynamicResource Auto_WebcamDevice}" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                    <ComboBox x:Name="WebcamComboBox" HorizontalAlignment="Stretch" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="core:WebcamSource">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="{DynamicResource Btn_Cancel}" Click="CancelButton_Click" Width="80" HorizontalContentAlignment="Center" Background="#333333" Foreground="#ECECEC"/>
            <Button Content="{DynamicResource Btn_OK}" Click="SaveButton_Click" Width="80" HorizontalContentAlignment="Center" Background="#0078D7" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
