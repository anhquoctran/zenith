<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Zenith.UI.Controls"
        xmlns:data="using:Zenith.Data"
        xmlns:core="using:Zenith.Core"
        xmlns:local="using:Zenith.UI.Views"
        xmlns:app="using:Zenith.UI"
        x:Class="Zenith.UI.Views.MainWindow"
        Title="{DynamicResource Auto_Zenith}"
        Icon="/Assets/logo.png"
        Width="1280" 
        Height="720"
        MinHeight="720"
        MinWidth="1280"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True">
    
    <Window.Resources>
        <local:PathToBitmapConverter x:Key="PathToBitmapConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="10"/>
        </Style>
        <Style Selector="Button.accent:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#0098FF"/>
        </Style>
    </Window.Styles>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32" /> <!-- Title Bar Area (Empty for dragging) -->
            <RowDefinition Height="Auto" /> <!-- Menu -->
            <RowDefinition Height="*" /> <!-- Main Layout -->
            <RowDefinition Height="Auto" /> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Top Menu Bar -->
        <Border Grid.Row="1" Height="30" Background="#1A1A1A" BorderBrush="#222222" BorderThickness="0,0,0,1">
            <Menu Background="Transparent" FontSize="12"  Foreground="#ECECEC" VerticalAlignment="Center" Margin="10,0,0,0">
                <MenuItem Header="{DynamicResource Menu_File}">
                    <MenuItem Header="{DynamicResource Menu_Settings}" HotKey="Ctrl+O" InputGesture="Ctrl+O" Click="Menu_Settings_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf013;"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Auto_ShowRecordings}" HotKey="Ctrl+R" InputGesture="Ctrl+R" Click="Menu_ShowRecordings_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf07b;"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_Exit}" HotKey="Alt+F4" InputGesture="Alt+F4" Click="Menu_Exit_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf08b;"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Edit}">
                    <MenuItem Header="{DynamicResource Menu_CopyLayer}" HotKey="Ctrl+C" InputGesture="Ctrl+C" Click="Menu_CopyLayer_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf0c5;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_CutLayer}" HotKey="Ctrl+X" InputGesture="Ctrl+X" Click="Menu_CutLayer_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf0c4;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_PasteLayer}" HotKey="Ctrl+V" InputGesture="Ctrl+V" Click="Menu_PasteLayer_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf0ea;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_DeleteLayer}" HotKey="Delete" InputGesture="Delete" Click="Menu_DeleteLayer_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf1f8;"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Layers}">
                    <MenuItem Header="{DynamicResource Menu_AddVideoSource}">
                        <MenuItem Header="{DynamicResource Type_Screen}" HotKey="Ctrl+1" InputGesture="Ctrl+1" Click="Menu_AddScreen_Click">
                            <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf108;"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Type_Image}" HotKey="Ctrl+2" InputGesture="Ctrl+2" Click="Menu_AddImage_Click">
                            <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf03e;"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Type_VideoFile}" HotKey="Ctrl+3" InputGesture="Ctrl+3" Click="Menu_AddVideoFile_Click">
                            <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf03d;"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Type_Text}" HotKey="Ctrl+4" InputGesture="Ctrl+4" Click="Menu_AddText_Click">
                            <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf031;"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Type_Camera}" HotKey="Ctrl+5" InputGesture="Ctrl+5" Click="Menu_AddCamera_Click">
                            <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf030;"/></MenuItem.Icon>
                        </MenuItem>
                        <MenuItem Header="{DynamicResource Type_FpsCounter}" HotKey="Ctrl+6" InputGesture="Ctrl+6" Click="Menu_AddFps_Click">
                            <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf0e4;"/></MenuItem.Icon>
                        </MenuItem>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_RemoveVideoSource}" HotKey="Shift+Delete" InputGesture="Shift+Delete" Click="RemoveVideoLayerButton_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf068;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_MoveSourceUp}" HotKey="Ctrl+Up" InputGesture="Ctrl+Up" Click="MoveUpVideoLayerButton_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf062;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_MoveSourceDown}" HotKey="Ctrl+Down" InputGesture="Ctrl+Down" Click="MoveDownVideoLayerButton_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf063;"/></MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="{DynamicResource Menu_AddAudioSource}" x:Name="MenuAddAudioSource">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf067;"/></MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="{DynamicResource Menu_RemoveAudioSource}" Click="RemoveAudioLayerButton_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf068;"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
                <MenuItem Header="{DynamicResource Menu_Help}">
                    <MenuItem Header="{DynamicResource Menu_About}" HotKey="F1" InputGesture="F1" Click="Menu_About_Click">
                        <MenuItem.Icon><TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf05a;"/></MenuItem.Icon>
                    </MenuItem>
                </MenuItem>
            </Menu>
        </Border>

        <!-- Main Content (OBS-style Layout) -->
        <Grid Grid.Row="2" RowDefinitions="*, 300" ColumnDefinitions="350, *, 300" Margin="4,4,4,4" RowSpacing="4" ColumnSpacing="4">
            
            <!-- Dock 0: History -->
            <Border Grid.Row="0" Grid.Column="0" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" Margin="0,0,0,10">
                        <TextBlock Grid.Column="0" Text="{DynamicResource Auto_RecordingHistory}" FontWeight="Bold" FontSize="12" Foreground="#ECECEC" VerticalAlignment="Center"/>
                        <Button x:Name="BtnClearHistory" Click="BtnClearHistory_Click" Grid.Column="1" ToolTip.Tip="{DynamicResource Auto_ClearHistory}" Width="28" Height="28" CornerRadius="14" Margin="0,0,5,0" Padding="0">
                            <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf1f8;" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <Button x:Name="BtnRefreshHistory" Click="BtnRefreshHistory_Click" Grid.Column="2" ToolTip.Tip="{DynamicResource Auto_Refresh}" Width="28" Height="28" CornerRadius="14" Padding="0">
                            <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf021;" FontSize="10" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                    </Grid>
                    
                    <ListBox x:Name="HistoryListBox" Grid.Row="1" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,-5,0,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="data:Record">
                                <Border Background="#2D2D30" CornerRadius="6" Padding="8" Margin="0,0,0,5">
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <Border Grid.Column="0" Width="60" Height="34" Background="#111111" CornerRadius="4" ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailPath, Converter={StaticResource PathToBitmapConverter}}" Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding FileName}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap" FontWeight="SemiBold" FontSize="13" Foreground="#ECECEC"/>
                                            <TextBlock Text="{Binding Resolution}" Foreground="#AAAAAA" FontSize="10" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{Binding Duration, StringFormat={}{0:hh\\:mm\\:ss}}" Foreground="#ECECEC" VerticalAlignment="Center" FontSize="11" FontWeight="Medium"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <StackPanel x:Name="EmptyHistoryPlaceholder" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="5" IsVisible="False">
                        <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" Foreground="#555555"/>
                        <TextBlock Text="{DynamicResource Auto_Norecordings}" FontSize="13" FontWeight="SemiBold" Foreground="#888888" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Preview Area -->
            <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" Margin="0" Background="#1A1A1A" BorderBrush="#333333" BorderThickness="1" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition MaxHeight="50" />
                    </Grid.RowDefinitions>

                    <Viewbox Grid.Row="0" Stretch="Uniform">
                        <Grid Width="1920" Height="1080">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="{Binding IsNotWindows}" ZIndex="10">
                                <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf071;" FontSize="120" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                <TextBlock Text="Live Preview is currently only supported on Windows" FontSize="36" FontWeight="SemiBold" Foreground="#888888" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <Image x:Name="PreviewImage" Stretch="Fill" />
                            <controls:VisualLayerEditor x:Name="LayerEditor" />
                        </Grid>
                    </Viewbox>

                    <Border Grid.Row="1" BorderThickness="1" Padding="15">
                        <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock x:Name="ElapsedTimeText" Text="00:00:00" Foreground="White" FontSize="13" FontWeight="Regular" HorizontalAlignment="Center" IsVisible="true"/>
                            <Button x:Name="RecordButton" Click="RecordButton_Click" Background="Transparent" Foreground="White" Width="38" Height="38" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_Record}">
                                <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf111;" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button x:Name="StopButton" Click="StopButton_Click" Background="Transparent" Foreground="White" Width="38" Height="38" HorizontalAlignment="Center" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" IsEnabled="False" ToolTip.Tip="{DynamicResource Auto_Stop}">
                                <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf04d;" FontSize="22" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- Dock 1: Sources (Video Layers) -->
            <Border Grid.Row="1" Grid.Column="0" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="{DynamicResource Lbl_Sources}" FontWeight="Bold" FontSize="12" Foreground="#ECECEC" Margin="0,0,0,5"/>
                    
                    <ListBox x:Name="VideoLayersListBox" Grid.Row="1" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" CornerRadius="0" Padding="0">
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="4,2"/>
                                <Setter Property="MinHeight" Value="24"/>
                            </Style>
                        </ListBox.Styles>
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="core:VideoLayer">
                                <Grid ColumnDefinitions="Auto, Auto, *, Auto" Margin="2">
                                    <Button Grid.Column="0" Background="Transparent" BorderThickness="0" Padding="0" Margin="5,0,5,0" VerticalAlignment="Center" Click="ToggleVisibilityButton_Click" ToolTip.Tip="{DynamicResource Auto_ToggleVisibility}">
                                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf06e;" Foreground="#AAAAAA" FontSize="10"/>
                                    </Button>
                                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Padding="0" Margin="0,0,10,0" VerticalAlignment="Center" Click="EditVideoLayerButton_Click" ToolTip.Tip="{DynamicResource Auto_Properties}">
                                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf044;" Foreground="#AAAAAA" FontSize="10"/>
                                    </Button>
                                    <TextBlock Grid.Column="2" Text="{Binding Name}" VerticalAlignment="Center" Foreground="#ECECEC" FontSize="12"/>
                                    <Button Grid.Column="3" Background="Transparent" BorderThickness="0" Padding="0" Margin="10,0,5,0" VerticalAlignment="Center" Click="ToggleLockButton_Click" ToolTip.Tip="{DynamicResource Auto_ToggleLock}">
                                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf09c;" Foreground="#555555" FontSize="10"/>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Border Grid.Row="2" Background="#2B2B2B" BorderThickness="1,0,1,1" BorderBrush="#333333" Height="26" Margin="0">
                        <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto">
                            <Button Grid.Column="0" Content="+" x:Name="AddVideoLayerButton" Click="AddVideoLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_AddSource}"/>
                            <Button Grid.Column="1" Content="-" x:Name="RemoveVideoLayerButton" Click="RemoveVideoLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_RemoveSource}"/>
                            
                            <ComboBox Grid.Column="2" x:Name="AddVideoLayerTypeComboBox" SelectedIndex="0" Height="20" FontSize="10" VerticalAlignment="Center" Margin="5,0" Padding="5,0" MinHeight="20">
                                <ComboBoxItem Content="{DynamicResource Auto_Screen}" />
                                <ComboBoxItem Content="{DynamicResource Auto_Image}" />
                                <ComboBoxItem Content="{DynamicResource Auto_VideoFile}" />
                                <ComboBoxItem Content="{DynamicResource Auto_Text}" />
                                <ComboBoxItem Content="{DynamicResource Auto_Camera}" />
                                <ComboBoxItem Content="{DynamicResource Auto_FPSCounter}" />
                            </ComboBox>

                            <Button Grid.Column="3" Content="^" x:Name="MoveUpVideoLayerButton" Click="MoveUpVideoLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_MoveUp}"/>
                            <Button Grid.Column="4" Content="{DynamicResource Auto_v}" x:Name="MoveDownVideoLayerButton" Click="MoveDownVideoLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_MoveDown}"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Dock 2: Mixer & Output -->
            <Border Grid.Row="1" Grid.Column="1" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid RowDefinitions="Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="{DynamicResource Lbl_AudioMixer}" FontWeight="Bold" FontSize="12" Foreground="#ECECEC" Margin="0,0,0,5"/>
                    
                    <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                        <ListBox x:Name="AudioLayersListBox" Background="#1E1E1E" BorderThickness="1" BorderBrush="#333333" CornerRadius="0" Padding="0">
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" Spacing="0"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate x:DataType="core:AudioLayer">
                                    <Border BorderThickness="0,0,0,1" BorderBrush="#333333" Background="Transparent" Padding="10,8">
                                        <Grid RowDefinitions="Auto, Auto, Auto">
                                            
                                            <!-- Row 0: Name and Options -->
                                            <Grid Grid.Row="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,8">
                                                <TextBlock Grid.Column="0" FontFamily="{StaticResource FontAwesome}" Text="&#xf028;" Foreground="#ECECEC" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Name}" TextAlignment="Left" TextTrimming="CharacterEllipsis" FontSize="12" FontWeight="SemiBold" Foreground="#ECECEC" VerticalAlignment="Center"/>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                                                    <TextBlock Text="{Binding Volume, StringFormat=\{0:0.0\} dB}" FontSize="11" Foreground="#888888" VerticalAlignment="Center"/>
                                                    <Button Background="Transparent" Padding="0" BorderThickness="0" Width="16" Height="16" VerticalAlignment="Center">
                                                        <TextBlock FontFamily="{StaticResource FontAwesome}" Text="&#xf013;" Foreground="#ECECEC" FontSize="12"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                            
                                            <!-- Row 1: Peak Meters -->
                                            <Grid Grid.Row="1" Margin="0,0,0,5" RowDefinitions="Auto, Auto">
                                                <ProgressBar Grid.Row="0" Orientation="Horizontal" Minimum="0" Maximum="1" Value="{Binding CurrentPeak}" Height="6" CornerRadius="0" BorderThickness="0" Background="#111111" Margin="0,0,0,2">
                                                    <ProgressBar.Foreground>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                            <GradientStop Color="#28A745" Offset="0.0" />
                                                            <GradientStop Color="#28A745" Offset="0.6" />
                                                            <GradientStop Color="#FFC107" Offset="0.75" />
                                                            <GradientStop Color="#DC3545" Offset="0.9" />
                                                        </LinearGradientBrush>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                                <ProgressBar Grid.Row="1" Orientation="Horizontal" Minimum="0" Maximum="1" Value="{Binding CurrentPeak}" Height="6" CornerRadius="0" BorderThickness="0" Background="#111111">
                                                    <ProgressBar.Foreground>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,0%">
                                                            <GradientStop Color="#28A745" Offset="0.0" />
                                                            <GradientStop Color="#28A745" Offset="0.6" />
                                                            <GradientStop Color="#FFC107" Offset="0.75" />
                                                            <GradientStop Color="#DC3545" Offset="0.9" />
                                                        </LinearGradientBrush>
                                                    </ProgressBar.Foreground>
                                                </ProgressBar>
                                            </Grid>
                                            
                                            <!-- Row 2: Volume Slider -->
                                            <Slider Grid.Row="2" Orientation="Horizontal" Value="{Binding Volume}" Minimum="0" Maximum="1" Height="20" Margin="0,0,0,0" VerticalAlignment="Center"/>
                                            
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </ScrollViewer>

                    <Border Grid.Row="2" Background="#2B2B2B" BorderThickness="1,0,1,1" BorderBrush="#333333" Height="26" Margin="0">
                        <Grid ColumnDefinitions="Auto, Auto, *">
                            <Button Grid.Column="0" Content="+" x:Name="AddAudioLayerButton" Click="AddAudioLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_AddAudioSource}"/>
                            <Button Grid.Column="1" Content="-" x:Name="RemoveAudioLayerButton" Click="RemoveAudioLayerButton_Click" Background="Transparent" Foreground="#ECECEC" BorderThickness="0" Width="24" Height="24" Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" ToolTip.Tip="{DynamicResource Auto_RemoveAudioSource}"/>
                            
                            <ComboBox Grid.Column="2" x:Name="AddAudioLayerTypeComboBox" SelectedIndex="0" Height="20" FontSize="10" VerticalAlignment="Center" Margin="5,0" Padding="5,0" MinHeight="20" HorizontalAlignment="Right">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate x:DataType="core:AudioSource">
                                        <TextBlock Text="{Binding Name}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- Dock 3: Settings -->
            <Border Grid.Row="1" Grid.Column="2" Background="#252526" BorderBrush="#333333" BorderThickness="1" Margin="0" Padding="5">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Settings moved to SettingsWindow -->
                    </Grid>
            </Border> 
        </Grid>

        <Border Grid.Row="3" Background="#111111" Padding="15,4" BorderBrush="#222222" BorderThickness="0,1,0,0" Height="28">
            <Grid ColumnDefinitions="*,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left" Spacing="15">
                    <TextBlock x:Name="AppVersionText" Text="{DynamicResource Auto_Zenithv100}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="FFmpegVersionText" Text="{DynamicResource Auto_FFmpegvXX}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="15">
                    <TextBlock x:Name="CpuUsageText" Text="{DynamicResource Auto_CPU0}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="MemUsageText" Text="{DynamicResource Auto_Mem0MB}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock x:Name="GpuUsageText" Text="{DynamicResource Auto_GPUNA}" FontSize="12" Foreground="#888888" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
