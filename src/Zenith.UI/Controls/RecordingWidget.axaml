<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Zenith.UI.Controls.RecordingWidget"
        Width="350" Height="60"
        WindowStartupLocation="CenterOwner"
        WindowDecorations="None"
        Topmost="True"
        Background="Transparent"
        TransparencyLevelHint="Transparent"
        CanResize="False">

    <Border Background="#E61E1E1E" CornerRadius="30" BorderBrush="#333333" BorderThickness="1" Padding="15,5" PointerPressed="Border_PointerPressed">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto">
            
            <Ellipse Grid.Column="0" Width="12" Height="12" Fill="#FF4444" VerticalAlignment="Center" Margin="0,0,10,0">
                <Ellipse.Styles>
                    <Style Selector="Ellipse">
                        <Style.Animations>
                            <Animation Duration="0:0:1" IterationCount="INFINITE" PlaybackDirection="Alternate">
                                <KeyFrame Cue="0%">
                                    <Setter Property="Opacity" Value="1.0" />
                                </KeyFrame>
                                <KeyFrame Cue="100%">
                                    <Setter Property="Opacity" Value="0.3" />
                                </KeyFrame>
                            </Animation>
                        </Style.Animations>
                    </Style>
                </Ellipse.Styles>
            </Ellipse>

            <TextBlock x:Name="TimerText" Grid.Column="1" Text="00:00:00" Foreground="White" FontWeight="Bold" FontSize="18" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Background="Transparent" Foreground="White" Width="36" Height="36" CornerRadius="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Margin="10,0,0,0" ToolTip.Tip="{DynamicResource Auto_Pause}">
                <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf04c;" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
            <Button Grid.Column="3" Background="Transparent" Foreground="#FF4444" Width="36" Height="36" CornerRadius="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Margin="5,0,0,0" ToolTip.Tip="{DynamicResource Auto_Stop}" Click="StopButton_Click">
                <TextBlock FontFamily="{StaticResource FontAwesome}" FontWeight="900" Text="&#xf04d;" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
            <Button Grid.Column="4" Content="📷" Background="Transparent" Foreground="White" Width="36" Height="36" CornerRadius="18" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" BorderThickness="0" Margin="5,0,0,0" ToolTip.Tip="{DynamicResource Auto_Snapshot}"/>
        </Grid>
    </Border>
</Window>
