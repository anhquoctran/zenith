<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:core="using:Zenith.Core"
             xmlns:local="using:Zenith.UI"
             xmlns:controls="using:Zenith.UI.Controls"
             x:Class="Zenith.UI.Controls.VisualLayerEditor"
             ClipToBounds="True"
             Focusable="True"
             KeyDown="UserControl_KeyDown">

    <UserControl.Styles>
        <Style Selector="Thumb.ResizeHandle">
            <Setter Property="Width" Value="10" />
            <Setter Property="Height" Value="10" />
            <Setter Property="Background" Value="#007ACC" />
            <Setter Property="BorderBrush" Value="White" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5" />
                </ControlTemplate>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Canvas x:Name="EditorCanvas" Background="Transparent"
            PointerPressed="EditorCanvas_PointerPressed"
            PointerMoved="EditorCanvas_PointerMoved"
            PointerReleased="EditorCanvas_PointerReleased">
        
        <ItemsControl x:Name="LayersItemsControl">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            
            <ItemsControl.Styles>
                <Style Selector="ContentPresenter" x:DataType="core:VideoLayer">
                    <Setter Property="Canvas.Left" Value="{Binding X}" />
                    <Setter Property="Canvas.Top" Value="{Binding Y}" />
                </Style>
            </ItemsControl.Styles>
            
            <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="core:VideoLayer">
                    <controls:VisualLayerItem Width="{Binding Width}" Height="{Binding Height}" />
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        
        <!-- We will dynamically generate bounding boxes and resize handles in Code-Behind for selected layers -->
        
    </Canvas>

</UserControl>
