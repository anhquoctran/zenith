<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Zenith.UI.App"
             RequestedThemeVariant="Dark">

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <FontFamily x:Key="FontAwesome">avares://Zenith.UI/Assets/Fonts/fa-solid-900.ttf#Font Awesome 5 Free Solid</FontFamily>
    </Application.Resources>

    <TrayIcon.Icons>
        <TrayIcons>
            <TrayIcon ToolTipText="Zenith Screen Recorder" Icon="/Assets/logo.png">
                <TrayIcon.Menu>
                    <NativeMenu>
                        <NativeMenuItem Header="Show Main Window" Click="NativeMenuItem_Show_Click" />
                        <NativeMenuItem Header="Stop Recording" Click="NativeMenuItem_Stop_Click" />
                        <NativeMenuItemSeparator />
                        <NativeMenuItem Header="Exit" Click="NativeMenuItem_Exit_Click" />
                    </NativeMenu>
                </TrayIcon.Menu>
            </TrayIcon>
        </TrayIcons>
    </TrayIcon.Icons>

</Application>