<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:core="using:Zenith.Core"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="Zenith.UI.LayerPropertiesWindow"
        Title="Layer Properties" Width="400" Height="450"
        WindowStartupLocation="CenterOwner"
        CanMaximize="False"
        CanMinimize="False"
        Background="#1E1E1E">
    <Grid RowDefinitions="Auto,*,Auto" Margin="15">
        <TextBlock Grid.Row="0" Text="Layer Properties" FontSize="16" FontWeight="Bold" Foreground="#ECECEC" Margin="0,0,0,15"/>
        
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="10">
                <TextBlock Text="Name" Foreground="#AAAAAA" FontSize="12"/>
                <TextBox x:Name="NameTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                
                <StackPanel x:Name="TextPropertiesPanel" Spacing="10" IsVisible="False">
                    <TextBlock Text="Text Content" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                    <TextBox x:Name="TextContentTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" AcceptsReturn="True" Height="80"/>
                    
                    <TextBlock Text="Font Family" Foreground="#AAAAAA" FontSize="12"/>
                    <TextBox x:Name="FontFamilyTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                    
                    <Grid ColumnDefinitions="*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Font Size" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <NumericUpDown x:Name="FontSizeNumeric" Minimum="8" Maximum="800" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,0,0">
                            <TextBlock Text="Font Color (Hex)" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <TextBox x:Name="FontColorTextBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333"/>
                        </StackPanel>
                    </Grid>
                    
                    <Grid ColumnDefinitions="*,*,*">
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="Font Style" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <ComboBox x:Name="FontStyleComboBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="Italic"/>
                                <ComboBoxItem Content="Oblique"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <TextBlock Text="Font Weight" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <ComboBox x:Name="FontWeightComboBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Normal"/>
                                <ComboBoxItem Content="Bold"/>
                                <ComboBoxItem Content="Light"/>
                                <ComboBoxItem Content="Black"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2" Margin="5,0,0,0">
                            <TextBlock Text="Alignment" Foreground="#AAAAAA" FontSize="12" Margin="0,0,0,10"/>
                            <ComboBox x:Name="TextAlignmentComboBox" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="Left"/>
                                <ComboBoxItem Content="Center"/>
                                <ComboBoxItem Content="Right"/>
                            </ComboBox>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="FilePropertiesPanel" Spacing="10" IsVisible="False">
                    <TextBlock Text="File Path" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                    <Grid ColumnDefinitions="*,Auto">
                        <TextBox x:Name="FilePathTextBox" Grid.Column="0" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333" Margin="0,0,5,0"/>
                        <Button x:Name="BrowseFileButton" Grid.Column="1" Content="..." Width="30" Click="BrowseFileButton_Click" Background="#333333" Foreground="#ECECEC" HorizontalContentAlignment="Center"/>
                    </Grid>
                </StackPanel>

                <StackPanel x:Name="CameraPropertiesPanel" Spacing="10" IsVisible="False">
                    <TextBlock Text="Webcam Device" Foreground="#AAAAAA" FontSize="12" Margin="0,10,0,0"/>
                    <ComboBox x:Name="WebcamComboBox" HorizontalAlignment="Stretch" Background="#2B2B2B" Foreground="#ECECEC" BorderBrush="#333333">
                        <ComboBox.ItemTemplate>
                            <DataTemplate x:DataType="core:WebcamSource">
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,20,0,0">
            <Button Content="Cancel" Click="CancelButton_Click" Width="80" HorizontalContentAlignment="Center" Background="#333333" Foreground="#ECECEC"/>
            <Button Content="Save" Click="SaveButton_Click" Width="80" HorizontalContentAlignment="Center" Background="#0078D7" Foreground="White"/>
        </StackPanel>
    </Grid>
</Window>
